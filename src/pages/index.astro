---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.jsx";
---

<Layout bgClass="bg-canvas text-ink">
	<div class="min-h-screen flex flex-col justify-center items-center pt-28 pb-20 px-8">
		<Hero client:load />
	</div>

	<section id="about" class="min-h-screen flex flex-col items-center justify-center px-8 bg-canvas text-ink">
		<div class="max-w-2xl mx-auto text-center">
			<h2 class="text-3xl font-serif mb-6">A bit about me</h2>
			<p class="font-sans leading-relaxed text-slate">
				add later.
			</p>
		</div>
	</section>
</Layout>