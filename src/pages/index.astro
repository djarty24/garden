---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.jsx";
import DraggableCrate from "../components/DraggableCrate.jsx";
import InteractiveAboutText from "../components/InteractiveAboutText.jsx";
import SelectedWorks from "../components/SelectedWorks.jsx";
---

<Layout bgClass="bg-canvas text-ink">
	<div class="min-h-screen flex flex-col justify-center items-center pt-28 pb-20 px-8">
		<Hero client:load />
	</div>

	<section id="about" class="min-h-screen py-32 px-8 bg-canvas">
		<div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
			
			<div class="flex flex-col gap-10">
				<h2 class="text-3xl md:text-4xl font-serif text-ink">A Bit About Me</h2>
				<InteractiveAboutText client:visible />
			</div>

			<div class="w-full aspect-square lg:sticky lg:top-32 flex items-center justify-center rounded-2xl">
				<DraggableCrate client:visible />
			</div>

		</div>
	</section>

	<SelectedWorks client:visible />
</Layout>