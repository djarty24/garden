---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.jsx";
import DraggableCrate from "../components/DraggableCrate.jsx";
---

<Layout bgClass="bg-canvas text-ink">
	<div class="min-h-screen flex flex-col justify-center items-center pt-28 pb-20 px-8">
		<Hero client:load />
	</div>

	<section id="about" class="min-h-screen py-32 px-8 bg-canvas">
		<div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
			
			<div class="flex flex-col gap-10">
				<h2 class="text-3xl md:text-4xl font-serif text-ink">A Bit About Me</h2>
				
				<div class="flex flex-col gap-6 font-sans leading-relaxed text-ink text-lg max-w-xl">
					<p>
						I'm a high school senior based in the Bay Area, CA. As of now I spend most of my time <span class="">researching BCIs</span>, working on KiCad schematics (currently participating in <a href="https://stasis.hackclub.com/" class="squiggly-underline text-ink hover:text-slate transition-colors">Hack Club's Stasis</a> event!), and over-engineering everything I own when I should be doing homework. Any space where tech can be used for good, I'm there.
					</p>
					<p>
						My work is often inspired by <span class="">impressionist art</span> and the tactile nature of analog objects. I believe in creating things that are <span class="">fun</span> and stretching my imagination. I hope to bring this philosophy to <span class="">UCSD</span> as a CS major this fall.
					</p>
					<p>
						When I'm not at my desk, you'll find me out for a run, taking photos with my digicam, or playing tabla to unwind.
					</p>
				</div>
			</div>

			<div class="w-full aspect-square lg:sticky lg:top-32 flex items-center justify-center rounded-2xl">
				<DraggableCrate client:visible />
			</div>

		</div>
	</section>
</Layout>