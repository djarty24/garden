---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Revati's Studio</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="min-h-screen relative selection:bg-lavender bg-canvas text-ink font-sans"
    >
        <header
            class="fixed top-0 left-0 right-0 w-full flex justify-between items-center p-8 z-50 pointer-events-none"
        >
            <div
                class="text-sm text-slate italic font-serif pointer-events-auto"
            >
                What makes us human?
            </div>
            <div
                class="text-xl font-serif text-slate/60 pointer-events-auto absolute left-1/2 -translate-x-1/2"
            >
                my studio
            </div>
            <button
                class="text-2xl pointer-events-auto hover:text-slate transition-colors"
                >+</button
            >
        </header>

        <slot />
    </body>
</html>
